Step 1: Create Layout.jsx
import { Link, Outlet } from "react-router-dom";

function Layout() {
    return (
        <div>
            <header>
                <h1>My Website</h1>
            </header>

            <nav>
                <Link to="/">Home</Link> |
                <Link to="/about">About</Link> |
                <Link to="/contact">Contact</Link>
            </nav>

            <hr />

            <Outlet />

            <hr />

            <footer>
                <p>© 2026 My Website</p>
            </footer>
        </div>
    );
}

export default Layout;
What is Outlet?

Outlet is where the matched page component will be rendered.

