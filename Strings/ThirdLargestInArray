public static void main(String[] args) {
        
        int [] nums = {8,3,3,7,9,4};
        
        int largest = Integer.MIN_VALUE;
        int second_largest = Integer.MIN_VALUE;
        int third_largest = Integer.MIN_VALUE;
        
        for(int num : nums){
            if(num > largest){
                third_largest = second_largest;
                second_largest = largest;
                largest = num;
                
            }
            
            else if(num > second_largest && num != largest){
                third_largest = second_largest;
                second_largest = num;
            }
            
            else if(num > third_largest && num != second_largest && num != largest){
                third_largest = num;
            }
        }
        
        
        System.out.println("largest: "+ largest + ", "+ "second largest: "+ second_largest + ","+ "third largest: "+third_largest);
    }
