class Main {
    public static void main(String[] args) {
        
        String s = "abcde";
        String goal = "cdeba";
        
        for(int i=0;i<s.length(); i++){
            String rotated = s.substring(i) + s.substring(0,i);
            
            if(rotated.equals(goal)){
                System.out.println("true");
            }
        }
        
        System.out.println("false");
        
    }
}
